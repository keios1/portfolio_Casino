    customEventName: WaitForEnemyAttack
  - image: {fileID: 0}
    title: "\uB9C8\uB140"
    content: "\uC557, \uC801\uC774 \uBE59\uACE0\uB97C \uC644\uC131\uD588\uC2B5\uB2C8\uB2E4!\n\uC801\uC758
      \uACF5\uACA9\uC73C\uB85C \uCCB4\uB825\uC774 \uAC10\uC18C\uD588\uC2B5\uB2C8\uB2E4!"
    progressType: 0
    targetButtonName: TopBarPanel
    showArrow: 0
    requiredActionName: 
    wrongActionMessage: 
    customEventName: 
  - image: {fileID: 0}
    title: "\uB9C8\uB140"
    content: "\uC870\uAE08 \uC704\uD5D8\uD55C \uC0C1\uD669\uC774\uB124\uC694!\n\uAC15\uB825\uD55C
      \uD2B8\uB77C\uC774\uC5C4\uD504 \uCE74\uB4DC\uC640 \uD544\uC694\uD55C \uC8FC\uC0AC\uC704\uB97C
