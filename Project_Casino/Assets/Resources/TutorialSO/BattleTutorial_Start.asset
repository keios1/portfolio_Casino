  - image: {fileID: 0}
    title: "\uB9C8\uB140"
    content: "\uB9E4 \uD134 \uC2DC\uC791 \uC2DC \uD589\uB3D9\uC5D0 \uC0AC\uC6A9\uD560
      \uC8FC\uC0AC\uC704\uB97C \uAD74\uB9BD\uB2C8\uB2E4.\n\uC774 \uCE78\uC5D0 \uC8FC\uC0AC\uC704\uAC00
      \uBC30\uCE58\uB429\uB2C8\uB2E4."
    progressType: 0
    targetButtonName: DiceTarget
    showArrow: 1
    requiredActionName: 
    wrongActionMessage: 
    customEventName: 
  - image: {fileID: 0}
    title: "\uB9C8\uB140"
    content: "\uD0C0\uACA9 \uCE74\uB4DC\uB97C \uB4DC\uB798\uADF8\uD574\uC11C \uD654\uBA74
      \uC911\uC559\uC73C\uB85C \uC62E\uACA8\uBCF4\uC138\uC694."
    progressType: 3
    targetButtonName: HandPanel, CardDropArea
    showArrow: 1
    requiredActionName: Basic_Card
    wrongActionMessage: "\uBA3C\uC800 \uACF5\uACA9 \uCE74\uB4DC\uB97C \uB4DC\uB798\uADF8\uD574\uC57C
      \uD569\uB2C8\uB2E4!"
    customEventName: 
  - image: {fileID: 0}
    title: "\uB9C8\uB140"
    content: "\uCE74\uB4DC\uB97C \uC911\uC559\uC73C\uB85C \uC62E\uACBC\uC2B5\uB2C8\uB2E4.
      \n\uC774\uC81C \uC9C0\uBD88\uD560 \uC8FC\uC0AC\uC704\uB97C \uD074\uB9AD\uD558\uC138\uC694."
    progressType: 3
    targetButtonName: DiceTarget, DicePanel
    showArrow: 1
    requiredActionName: SelectDice
    wrongActionMessage: "\uBC29\uAE08 \uB0B8 \uCE74\uB4DC\uC5D0 \uC0AC\uC6A9\uD560
      \uC8FC\uC0AC\uC704\uB97C \uC120\uD0DD\uD558\uC138\uC694!"
    customEventName: 
  - image: {fileID: 0}
    title: "\uB9C8\uB140"
    content: "\uC88B\uC544\uC694! \uC8FC\uC0AC\uC704\uB97C \uC120\uD0DD\uD588\uC2B5\uB2C8\uB2E4.\n\uC774\uC81C
      \uACF5\uACA9\uD560 \uC801\uC744 \uD074\uB9AD\uD558\uC138\uC694."
    progressType: 3
    targetButtonName: EnemyClick
    showArrow: 1
    requiredActionName: SelectEnemy
    wrongActionMessage: "\uC801\uC744 \uD074\uB9AD\uD574\uC11C \uACF5\uACA9\uC744
      \uC9C4\uD589\uD574 \uC8FC\uC138\uC694!"
    customEventName: ReadyForAttackTutorial
  - image: {fileID: 0}
    title: "\uB9C8\uB140"
    content: "\uACF5\uACA9\uC744 \uC131\uACF5\uC801\uC73C\uB85C \uB9C8\uCCE4\uC2B5\uB2C8\uB2E4.\n\uD134
      \uC885\uB8CC \uBC84\uD2BC\uC744 \uB20C\uB7EC \uC801\uC5D0\uAC8C \uCC28\uB840\uB97C
      \uB118\uAE30\uC138\uC694."
    progressType: 3
    targetButtonName: 'TurnEndTarget, EndTurn '
    showArrow: 1
    requiredActionName: EndTurn
    wrongActionMessage: "\uACF5\uACA9\uC744 \uB9C8\uCCE4\uC73C\uB2C8 \uD134 \uC885\uB8CC\uB97C
      \uB20C\uB7EC\uC8FC\uC138\uC694!"
    customEventName: EnemyTurnStart
  - image: {fileID: 0}
    title: "\uB9C8\uB140"
    content: "\uC801\uC758 \uD134\uC785\uB2C8\uB2E4.\n\uC801\uC740 \uC815\uD574\uC9C4
      \uD328\uD134\uC73C\uB85C \uACF5\uACA9\uC744 \uC9C4\uD589\uD569\uB2C8\uB2E4."
