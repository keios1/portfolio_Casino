    customEventName: UnlockLookUp
  - image: {fileID: 0}
    title: "\uB9C8\uB140"
    content: "\uB9C8\uC74C\uC5D0 \uB4DC\uB294 \uCE74\uB4DC\uAC00 \uC788\uB2E4\uBA74
      \uD074\uB9AD\uD574\uBCF4\uC138\uC694.\n\uD655\uB300\uB41C \uCE74\uB4DC\uC640
